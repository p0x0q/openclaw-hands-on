{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-5"
      },
      "sandbox": {
        "mode": "off"
      },
      "memorySearch": {
        "enabled": false
      }
    },
    "list": [
      {
        "id": "default",
        "default": true,
        "workspace": "/home/node/.openclaw/workspace-default",
        "identity": { "name": "Default Agent" }
      }
    ]
  },
  "channels": {
    "slack": {
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "groupPolicy": "open"
    }
  },
  "bindings": [
    {
      "agentId": "default",
      "match": { "channel": "slack" }
    }
  ]
}
